{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "wechat-devtool",
  "title": "WeChat DevTool",
  "description": "Quickly open and manage WeChat Mini Program projects using the official CLI with multi-device support.",
  "icon": "icon.png",
  "author": "tofrankie",
  "license": "MIT",
  "scripts": {
    "dev": "ray develop",
    "build": "ray build -e dist",
    "lint": "ray lint",
    "fix-lint": "ray lint --fix",
    "publish": "ray publish"
  },
  "dependencies": {
    "@raycast/api": "^1.93.1",
    "@raycast/utils": "^1.19.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "18.18.4",
    "@types/react": "18.2.27",
    "eslint": "^8.57.1",
    "prettier": "^3.6.0",
    "typescript": "^5.8.3"
  },
  "categories": [
    "Developer Tools"
  ],
  "commands": [
    {
      "name": "open-project",
      "title": "Open Mini Program Project",
      "subtitle": "WeChat DevTool",
      "description": "Quickly open a configured Mini Program project in WeChat DevTool",
      "mode": "view"
    },
    {
      "name": "configure",
      "title": "Configure Extension",
      "subtitle": "Settings & Preferences",
      "description": "Configure devices and projects",
      "mode": "view"
    }
  ]
}
