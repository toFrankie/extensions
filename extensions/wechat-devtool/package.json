{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "wechat-devtool",
  "title": "WeChat Devtool",
  "description": "Quickly manage and open WeChat Mini Program projects using the official CLI. Supports multiple devices and projects.",
  "author": "tofrankie",
  "version": "0.1.0",
  "license": "MIT",
  "categories": [
    "Developer Tools"
  ],
  "icon": "wechat.png",
  "commands": [
    {
      "name": "open-project",
      "title": "Open Mini Program Project",
      "mode": "view"
    },
    {
      "name": "setup-config",
      "title": "Setup WeChat Projects",
      "mode": "modal"
    }
  ],
  "scripts": {
    "dev": "ray dev",
    "build": "ray build -e dist",
    "lint": "ray lint",
    "fix-lint": "ray lint --fix",
    "publish": "npx @raycast/api@latest publish"
  },
  "dependencies": {
    "@raycast/api": "^1.100.0",
    "@raycast/utils": "^2.0.1"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.0.4",
    "@types/node": "^20.19.1",
    "@types/react": "^19.1.8",
    "eslint": "^8.57.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  }
}
